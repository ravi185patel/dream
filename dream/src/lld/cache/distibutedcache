public class CacheNode {
    private final String nodeId;
    private final LRUCache localCache;
    private final ReplicationManager replicationManager;
    private final ExpirationManager expirationManager;
    
    public CompletableFuture<byte[]> get(String key) {
        byte[] value = localCache.get(key);
        return CompletableFuture.completedFuture(value);
    }
    
    public CompletableFuture<Boolean> put(String key, byte[] value, long ttl) {
        localCache.put(key, value, ttl);
        
        // Async replication to replicas
        return replicationManager.replicate(key, value, ttl);
    }
    
    public CompletableFuture<Boolean> delete(String key) {
        localCache.delete(key);
        return replicationManager.replicateDelete(key);
    }
}
