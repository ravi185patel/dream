public class ReplicationManager {
    private final List<CacheNodeClient> replicas;
    private final ReplicationMode mode;  // SYNC, ASYNC, SEMI_SYNC
    
    public CompletableFuture<Boolean> replicate(String key, byte[] value, long ttl) {
        List<CompletableFuture<Boolean>> futures = replicas.stream()
            .map(replica -> replica.put(key, value, ttl))
            .collect(Collectors.toList());
        
        switch (mode) {
            case SYNC:
                // Wait for all replicas
                return CompletableFuture.allOf(futures.toArray(new CompletableFuture[0]))
                    .thenApply(v -> true);
                    
            case SEMI_SYNC:
                // Wait for at least one replica (quorum)
                return CompletableFuture.anyOf(futures.toArray(new CompletableFuture[0]))
                    .thenApply(v -> true);
                    
            case ASYNC:
                // Fire and forget
                return CompletableFuture.completedFuture(true);
        }
    }
}
5. Client Library / Proxy
java


public class CacheClient {
    private final ConsistentHashRing ring;
    private final Map<String, CacheNodeClient> nodeClients;
    private final int replicationFactor;
    
    public CompletableFuture<byte[]> get(String key) {
        String nodeId = ring.getNode(key);
        return nodeClients.get(nodeId).get(key)
            .exceptionally(ex -> {
                // Fallback to replica on primary failure
                return getFromReplica(key);
            });
    }
    
    public CompletableFuture<Boolean> put(String key, byte[] value, long ttl) {
        List<String> nodes = ring.getNodes(key, replicationFactor);
        String primary = nodes.get(0);
        return nodeClients.get(primary).put(key, value, ttl);
    }
    
    // Connection pooling per node
    private CacheNodeClient getOrCreateClient(String nodeId) {
        return nodeClients.computeIfAbsent(nodeId, 
            id -> new CacheNodeClient(id, connectionPool));
    }
}
