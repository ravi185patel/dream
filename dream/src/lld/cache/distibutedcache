In-Memory Storage — HashMap + Doubly Linked List (for LRU)

java


public class LRUCache {
    private final int capacity;
    private final Map<String, Node> map;
    private final DoublyLinkedList dll;
    private final ReadWriteLock lock = new ReentrantReadWriteLock();
    
    public byte[] get(String key) {
        lock.readLock().lock();
        try {
            Node node = map.get(key);
            if (node == null || node.entry.isExpired()) {
                return null;
            }
            // Move to front (most recently used)
            promoteNode(node);
            return node.entry.value;
        } finally {
            lock.readLock().unlock();
        }
    }
    
    public void put(String key, byte[] value, long ttlMs) {
        lock.writeLock().lock();
        try {
            if (map.containsKey(key)) {
                updateExisting(key, value, ttlMs);
            } else {
                if (map.size() >= capacity) {
                    evictLRU();
                }
                insertNew(key, value, ttlMs);
            }
        } finally {
            lock.writeLock().unlock();
        }
    }
    
    private void evictLRU() {
        Node tail = dll.removeTail();
        map.remove(tail.entry.key);
    }
}
3.2 Consistent Hashing for Partitioning
java


public class ConsistentHashRing {
    private final TreeMap<Long, String> ring = new TreeMap<>();
    private final int virtualNodes;
    private final HashFunction hashFunction;
    
    public ConsistentHashRing(int virtualNodes) {
        this.virtualNodes = virtualNodes;  // Typically 100-200
        this.hashFunction = Hashing.murmur3_128();
    }
    
    public void addNode(String nodeId) {
        for (int i = 0; i < virtualNodes; i++) {
            long hash = hash(nodeId + "#" + i);
            ring.put(hash, nodeId);
        }
    }
    
    public void removeNode(String nodeId) {
        for (int i = 0; i < virtualNodes; i++) {
            long hash = hash(nodeId + "#" + i);
            ring.remove(hash);
        }
    }
    
    public String getNode(String key) {
        if (ring.isEmpty()) return null;
        long hash = hash(key);
        // Find first node clockwise
        Map.Entry<Long, String> entry = ring.ceilingEntry(hash);
        return (entry != null) ? entry.getValue() : ring.firstEntry().getValue();
    }
    
    // Get N nodes for replication
    public List<String> getNodes(String key, int count) {
        Set<String> nodes = new LinkedHashSet<>();
        long hash = hash(key);
        
        for (Map.Entry<Long, String> entry : ring.tailMap(hash).entrySet()) {
            nodes.add(entry.getValue());
            if (nodes.size() == count) break;
        }
        
        if (nodes.size() < count) {
            for (Map.Entry<Long, String> entry : ring.entrySet()) {
                nodes.add(entry.getValue());
                if (nodes.size() == count) break;
            }
        }
        return new ArrayList<>(nodes);
    }
    
    private long hash(String key) {
        return hashFunction.hashString(key, StandardCharsets.UTF_8).asLong();
    }
}
3.3 Cache Node Server
