public class HealthChecker {
    private final ScheduledExecutorService scheduler;
    private final Map<String, NodeHealth> nodeHealthMap;
    private final int failureThreshold = 3;
    
    public void startHealthChecks() {
        scheduler.scheduleAtFixedRate(() -> {
            for (String nodeId : nodeHealthMap.keySet()) {
                checkNode(nodeId);
            }
        }, 0, 1, TimeUnit.SECONDS);
    }
    
    private void checkNode(String nodeId) {
        try {
            boolean healthy = nodeClients.get(nodeId).ping()
                .get(100, TimeUnit.MILLISECONDS);
            
            if (healthy) {
                nodeHealthMap.get(nodeId).resetFailures();
            }
        } catch (Exception e) {
            NodeHealth health = nodeHealthMap.get(nodeId);
            health.incrementFailures();
            
            if (health.consecutiveFailures >= failureThreshold) {
                handleNodeFailure(nodeId);
            }
        }
    }
    
