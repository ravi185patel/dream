public class ExpirationManager {
    // Lazy expiration: check on access
    // Active expiration: background thread
    
    private final DelayQueue<ExpirableKey> expirationQueue;
    private final LRUCache cache;
    
    public ExpirationManager(LRUCache cache) {
        this.cache = cache;
        this.expirationQueue = new DelayQueue<>();
        startExpirationThread();
    }
    
    public void scheduleExpiration(String key, long ttlMs) {
        expirationQueue.offer(new ExpirableKey(key, ttlMs));
    }
    
    private void startExpirationThread() {
        Thread expirationThread = new Thread(() -> {
            while (true) {
                try {
                    ExpirableKey expired = expirationQueue.take();
                    cache.deleteIfExpired(expired.key);
                } catch (InterruptedException e) {
                    Thread.currentThread().interrupt();
                    break;
                }
            }
        });
        expirationThread.setDaemon(true);
        expirationThread.start();
    }
    
