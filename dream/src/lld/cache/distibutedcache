7.2 Write-Behind (Async Persistence)
java


public class WriteBehindManager {
    private final BlockingQueue<WriteOperation> writeQueue;
    private final PersistenceStore persistenceStore;
    
    public void scheduleWrite(String key, byte[] value) {
        writeQueue.offer(new WriteOperation(key, value));
    }
    
    private void startWriterThread() {
        Thread writer = new Thread(() -> {
            List<WriteOperation> batch = new ArrayList<>();
            while (true) {
                writeQueue.drainTo(batch, 100);
                if (!batch.isEmpty()) {
                    persistenceStore.batchWrite(batch);
                    batch.clear();
                }
                Thread.sleep(10);  // Batch interval
            }
        });
        writer.start();
    }
}
